<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sınav Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <div class="d-flex" id="wrapper">
        <div class="sidebar shadow-sm" id="sidebar">
            <div class="sidebar-heading text-center py-4 fw-bold fs-4 border-bottom border-secondary">
                <i class="fas fa-graduation-cap text-primary me-2"></i>Sınav Portal
            </div>
            <div class="list-group list-group-flush my-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Teacher"))
                    {
                        <a href="/Teacher/Index" class="list-group-item list-group-item-action bg-transparent text-white fw-semibold"><i class="fas fa-tasks me-3"></i>Sınav Yönetimi</a>
                        <a href="/Teacher/UserManagement" class="list-group-item list-group-item-action bg-transparent text-white fw-semibold"><i class="fas fa-users-cog me-3"></i>Kullanıcılar</a>
                    }
                    else
                    {
                        <a href="/Student/Exams" class="list-group-item list-group-item-action bg-transparent text-white fw-semibold"><i class="fas fa-pencil-alt me-3"></i>Sınavlarım</a>
                        <a href="/Student/MyResults" class="list-group-item list-group-item-action bg-transparent text-white fw-semibold"><i class="fas fa-history me-3"></i>Geçmiş</a>
                    }
                }
            </div>
        </div>

        <div id="page-content-wrapper" class="w-100 bg-light">
            <nav class="navbar navbar-expand-lg navbar-light bg-white py-3 px-4 shadow-sm">
                <div class="d-flex align-items-center">
                    <i class="fas fa-bars fs-4 me-3 text-secondary" id="menu-toggle" style="cursor:pointer;"></i>
                    <h5 class="m-0 fw-bold text-dark">@ViewData["Title"]</h5>
                </div>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-semibold text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                    <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=4f46e5&color=fff&rounded=true" alt="Profil" class="rounded-circle me-1" width="30" height="30">
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                    <li><a class="dropdown-item py-2" href="/Home/Profile"><i class="fas fa-user me-2 text-muted"></i>Profilim</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger py-2" href="/Auth/Logout"><i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link fw-semibold" href="/Auth/Login"><i class="fas fa-sign-in-alt me-1"></i>Giriş</a></li>
                            <li class="nav-item"><a class="btn btn-primary ms-2 px-4 rounded-pill shadow-sm" href="/Auth/Register">Kaydol</a></li>
                        }
                    </ul>
                </div>
            </nav>

            <div class="container-fluid p-4">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm">
                        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>

            <footer class="text-center py-3 text-muted small mt-auto">
                &copy; @DateTime.Now.Year - Sınav Portal Yönetim Sistemi
            </footer>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById("menu-toggle").addEventListener("click", function (e) {
            e.preventDefault();
            document.getElementById("wrapper").classList.toggle("toggled");
        });
    </script>
    @RenderSection("Scripts", required: false)
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>