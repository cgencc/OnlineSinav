<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Online Sınav Portalı</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome ikonlar -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><i class="fas fa-graduation-cap me-2"></i>Online Sınav</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Teacher"))
                        {
                            <li class="nav-item"><a class="nav-link" href="/Teacher/Index"><i class="fas fa-tasks me-1"></i>Sınav Yönetimi</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" href="/Student/Exams"><i class="fas fa-pencil-alt me-1"></i>Sınavlarım</a></li>
                        }
                        <li class="nav-item"><a class="nav-link text-white-50"><i class="fas fa-user-circle me-1"></i>@User.Identity.Name</a></li>
                        <li class="nav-item"><a class="nav-link btn btn-outline-light btn-sm ms-2 px-3" href="/Auth/Logout"><i class="fas fa-sign-out-alt me-1"></i>Çıkış</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Auth/Login"><i class="fas fa-sign-in-alt me-1"></i>Giriş Yap</a></li>
                        <li class="nav-item"><a class="nav-link btn btn-primary btn-sm ms-2 px-3" href="/Auth/Register"><i class="fas fa-user-plus me-1"></i>Kaydol</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <footer class="footer mt-5 py-3 bg-light text-center text-muted">
        <small>&copy; @DateTime.Now.Year - Online Sınav Portalı</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>