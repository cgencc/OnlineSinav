@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<h2 class="mb-4"><i class="fas fa-users-cog me-2"></i>Kullanıcı Yönetimi</h2>

<table class="table table-striped table-hover shadow-sm" id="usersTable">
    <thead class="table-dark">
        <tr><th>Kullanıcı Adı</th><th>Ad Soyad</th><th>Öğrenci No</th><th>Rol</th><th>İşlem</th></tr>
    </thead>
    <tbody>
        <!-- AJAX ile doldurulacak -->
    </tbody>
</table>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        $(function(){
            function loadUsers() {
                $.get('/Teacher/GetUsers', function(res) {
                    var rows = '';
                    if (res.status && res.data) {
                        $.each(res.data, function(i, u){
                            var roleBtn = u.rol === 'Teacher'
                                ? `<button class="btn btn-sm btn-warning revoke-btn" data-username="${u.userName}">Yetkiyi Al</button>`
                                : `<button class="btn btn-sm btn-success make-btn" data-username="${u.userName}">Öğretmen Yap</button>`;
                            rows += `<tr>
                                <td>${u.userName}</td>
                                <td>${u.fullName}</td>
                                <td>${u.studentNumber || '-'}</td>
                                <td><span class="badge ${u.rol==='Teacher'?'bg-primary':'bg-secondary'}">${u.rol}</span></td>
                                <td>${roleBtn}</td>
                            </tr>`;
                        });
                    } else {
                        rows = '<tr><td colspan="5" class="text-center text-muted">Kullanıcı bulunamadı.</td></tr>';
                    }
                    $('#usersTable tbody').html(rows);
                });
            }
            loadUsers();

            $(document).on('click', '.make-btn', function(){
                var uname = $(this).data('username');
                $.post('/Teacher/MakeTeacher', JSON.stringify({ userName: uname }), function(res){
                    alert(res.message);
                    loadUsers();
                }, 'json');
            });

            $(document).on('click', '.revoke-btn', function(){
                var uname = $(this).data('username');
                $.post('/Teacher/RevokeTeacher', JSON.stringify({ userName: uname }), function(res){
                    alert(res.message);
                    loadUsers();
                }, 'json');
            });
        });
    </script>
}