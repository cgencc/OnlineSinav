@{
    ViewData["Title"] = "Sinav Olustur / Duzenle";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0"><i class="fas fa-graduation-cap me-2"></i>Sinav Bilgileri</h5>
            </div>
            <div class="card-body p-4">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Sinav Adi *</label>
                    <input type="text" id="examTitle" class="form-control" placeholder="Ornek: Matematik Vize Sinavi" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Aciklama</label>
                    <textarea id="examDescription" class="form-control" rows="2" placeholder="Isteğe bagli aciklama"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Sure (Dakika) *</label>
                    <input type="number" id="examDuration" class="form-control" min="1" max="300" value="60" />
                </div>

                <hr />
                <p class="text-muted small mb-2"><i class="fas fa-clock me-1"></i>Sinav Tarihi Araligi — Bos birakilirsa her zaman erisebilir.</p>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Baslangic Tarihi</label>
                        <input type="datetime-local" id="startDate" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Bitis Tarihi</label>
                        <input type="datetime-local" id="endDate" class="form-control" />
                    </div>
                </div>

                <div class="mb-4" id="isActiveWrapper" style="display:none;">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="isActive" checked />
                        <label class="form-check-label fw-semibold" for="isActive">Sinav Aktif</label>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button id="btnSave" class="btn btn-primary px-4">
                        <i class="fas fa-save me-2"></i>Kaydet
                    </button>
                    <a href="/Teacher/Index" class="btn btn-outline-secondary px-4">
                        <i class="fas fa-arrow-left me-2"></i>Geri
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            var examId = @(Model is int id ? id.ToString() : "0");
            var isEdit = examId > 0;

            if (isEdit) {
                document.title = 'Sinavi Duzenle';
                $('#isActiveWrapper').show();

                $.get('/Teacher/GetExam?id=' + examId, function (exam) {
                    if (!exam) return;
                    $('#examTitle').val(exam.title || '');
                    $('#examDescription').val(exam.description || '');
                    $('#examDuration').val(exam.durationInMinutes || 60);
                    $('#isActive').prop('checked', exam.isActive !== false);
                    if (exam.startDate) $('#startDate').val(toLocalInput(exam.startDate));
                    if (exam.endDate)   $('#endDate').val(toLocalInput(exam.endDate));
                });
            }

            function toLocalInput(isoStr) {
                var d = new Date(isoStr);
                var pad = function(n){ return n < 10 ? '0' + n : n; };
                return d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate())
                     + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
            }

            function showToast(msg, type) {
                Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 })
                    .fire({ icon: type === 'danger' ? 'error' : type, title: msg });
            }

            $('#btnSave').on('click', function () {
                var title    = $.trim($('#examTitle').val());
                var duration = parseInt($('#examDuration').val());
                var start    = $('#startDate').val();
                var end      = $('#endDate').val();

                if (!title) { showToast('Sinav adi zorunludur!', 'warning'); return; }
                if (!duration || duration < 1) { showToast('Sure en az 1 dakika olmalidir!', 'warning'); return; }
                if (start && end && new Date(start) >= new Date(end)) {
                    showToast('Bitis tarihi baslangictan sonra olmalidir!', 'warning'); return;
                }

                var payload = {
                    title:             title,
                    description:       $.trim($('#examDescription').val()),
                    durationInMinutes: duration,
                    startDate:         start || null,
                    endDate:           end   || null
                };

                if (isEdit) {
                    payload.id       = examId;
                    payload.isActive = $('#isActive').prop('checked');

                    $.ajax({
                        url:         '/Teacher/UpdateExam',
                        type:        'PUT',
                        contentType: 'application/json',
                        data:        JSON.stringify(payload),
                        success: function (res) {
                            if (res && res.status) {
                                showToast('Sinav guncellendi!', 'success');
                                setTimeout(function(){ window.location = '/Teacher/Index'; }, 1200);
                            } else {
                                showToast(res ? res.message : 'Hata olustu', 'danger');
                            }
                        },
                        error: function (xhr) { showToast('Hata: HTTP ' + xhr.status, 'danger'); }
                    });
                } else {
                    $.ajax({
                        url:         '/Teacher/CreateExam',
                        type:        'POST',
                        contentType: 'application/json',
                        data:        JSON.stringify(payload),
                        success: function (res) {
                            if (res && res.status) {
                                showToast('Sinav olusturuldu! Simdi sorulari ekleyebilirsiniz.', 'success');
                                var newId = res.data || (res.Data);
                                setTimeout(function(){
                                    window.location = '/Teacher/Questions?examId=' + newId;
                                }, 1400);
                            } else {
                                showToast(res ? res.message : 'Hata olustu', 'danger');
                            }
                        },
                        error: function (xhr) { showToast('Hata: HTTP ' + xhr.status, 'danger'); }
                    });
                }
            });
        });
    </script>
}
