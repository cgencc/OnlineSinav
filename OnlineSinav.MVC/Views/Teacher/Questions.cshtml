@model int
@* ExamId *@
@{
    ViewData["Title"] = "Soruları Yönet";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h2><i class="fas fa-question-circle me-2"></i>Soruları Yönet</h2>
        <a href="/Teacher/Index" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>Geri</a>
    </div>

    <div id="alertBox"></div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-2">Sınav Toplam Puanı</h6>
                    <h2 class="fw-bold text-primary mb-0"><span id="totalPoints">0</span> / 100</h2>
                    <span class="small text-muted">Kalan: <strong id="remainingPoints">100</strong> puan</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white fw-bold">
            <i class="fas fa-list me-1"></i> Mevcut Sorular
        </div>
        <div class="card-body" id="existingQuestions">
            <p class="text-muted text-center py-3">Yükleniyor...</p>
        </div>
    </div>


    <div class="card shadow-sm">
        <div class="card-header bg-success text-white fw-bold">
            <i class="fas fa-plus-circle me-1"></i> Yeni Soru Ekle
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-semibold">Soru Metni</label>
                <textarea id="QuestionText" class="form-control" rows="3" placeholder="Soruyu buraya yazın..." required></textarea>
            </div>
            <div class="mb-3 col-md-3">
                <label class="form-label fw-semibold">Puan</label>
                <input id="Points" type="number" class="form-control" value="10" min="1" max="100" />
            </div>

            <hr />
            <h6 class="fw-bold mb-3"><i class="fas fa-list me-1"></i>Şıklar</h6>
            <div id="optionsList"></div>

            <button type="button" class="btn btn-outline-secondary btn-sm mb-3" id="addOptionBtn">
                <i class="fas fa-plus me-1"></i>Şık Ekle
            </button>

            <div class="d-grid mt-2">
                <button type="button" class="btn btn-success btn-lg" id="saveQuestionBtn">
                    <i class="fas fa-save me-1"></i>Soruyu Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editQuestionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold"><i class="fas fa-edit me-2"></i>Soruyu Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editQuestionId" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Soru Metni</label>
                    <textarea id="editQuestionText" class="form-control" rows="3" required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Puan</label>
                    <input id="editPoints" type="number" class="form-control" min="1" max="100" required />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-warning text-dark fw-bold" id="btnUpdateQuestion">
                    <i class="fas fa-save me-1"></i>Güncelle
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        var examId = @Model;
        var optionCount = 0;
        var currentTotal = 0;

        function showAlert(msg, type) {

            var iconType = type === 'danger' ? 'error' : type;


            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            Toast.fire({
                icon: iconType,
                title: msg
            });
        }

        function updateTotalDisplay(total) {
            $('#totalPoints').text(total);
            $('#remainingPoints').text(100 - total);
            if (total > 100) {
                $('#totalPoints').addClass('text-danger').removeClass('text-primary');
            } else {
                $('#totalPoints').removeClass('text-danger').addClass('text-primary');
            }
        }

        function loadExistingQuestions() {
            $.get(`/Teacher/GetExam/${examId}`, function(data) {
                var html = '';
                currentTotal = 0;
                if (data && data.questions && data.questions.length > 0) {
                    $.each(data.questions, function(i, q) {
   
                        var optionsHtml = '';
                        if (q.options) {
                            $.each(q.options, function(j, opt) {
                                optionsHtml += `<li>${opt.optionText}</li>`;
                            });
                        }
                        currentTotal += q.points || 0;

                        html += `
                        <div class="card mb-2 border-secondary" id="questionCard_${q.id}">
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <strong>#${i+1}: ${q.questionText}</strong>
                                        <span class="badge bg-primary ms-2">${q.points} puan</span>
                                        ${q.options ? `<ul class="mb-0 mt-1 small">${optionsHtml}</ul>` : ''}
                                    </div>
                                    <div class="btn-group ms-2">
                                        <button class="btn btn-sm btn-outline-warning btn-edit-question" data-id="${q.id}" data-text="${q.questionText}" data-points="${q.points}">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger btn-delete-question" data-id="${q.id}">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>`;
                    });
                } else {
                    html = '<p class="text-muted text-center py-3">Henüz soru eklenmemiş.</p>';
                }
                $('#existingQuestions').html(html);
                updateTotalDisplay(currentTotal);
            });
        }

        function addOptionRow(text, isCorrect) {
            optionCount++;
            var idx = optionCount;
            var row = `
            <div class="input-group mb-2" id="optRow_${idx}">
                <div class="input-group-text">
                    <input class="form-check-input mt-0 correct-radio" type="radio" name="correctOption" value="${idx}" title="Doğru cevap" ${isCorrect ? 'checked' : ''} />
                </div>
                <input type="text" class="form-control option-text" placeholder="Şık metni" value="${text || ''}" />
                <button class="btn btn-outline-danger" type="button" onclick="$('#optRow_${idx}').remove()">
                    <i class="fas fa-trash"></i>
                </button>
            </div>`;
            $('#optionsList').append(row);
        }

        $(function () {

            loadExistingQuestions();


            addOptionRow('', false);
            addOptionRow('', false);
            addOptionRow('', false);
            addOptionRow('', false);
            $('input[name="correctOption"]').first().prop('checked', true);

            $('#addOptionBtn').click(function () {
                addOptionRow('', false);
            });

            $('#saveQuestionBtn').click(function () {
                var questionText = $('#QuestionText').val().trim();
                var points = parseInt($('#Points').val()) || 10;

                if (!questionText) {
                    showAlert('Soru metni boş bırakılamaz.', 'danger');
                    return;
                }

              
                if (currentTotal + points > 100) {
                    showAlert(`Sınav toplam puanı 100'ü aşıyor! Kalan puan: ${100 - currentTotal}`, 'danger');
                    return;
                }

                var options = [];
                var correctIdx = $('input[name="correctOption"]:checked').val();
                var hasCorrect = false;
                var valid = true;

                $('#optionsList .input-group').each(function (i) {
                    var rowId = $(this).attr('id').replace('optRow_', '');
                    var text = $(this).find('.option-text').val().trim();
                    if (!text) {
                        valid = false;
                        return false;
                    }
                    var isCorrect = (rowId === correctIdx);
                    if (isCorrect) hasCorrect = true;
                    options.push({ text: text, isCorrect: isCorrect });
                });

                if (!valid) { showAlert('Tüm şık metinlerini doldurun.', 'danger'); return; }
                if (options.length < 2) { showAlert('En az 2 şık ekleyin.', 'danger'); return; }
                if (!hasCorrect) { showAlert('Doğru cevabı işaretleyin (soldaki radyo butonu).', 'danger'); return; }

                var $btn = $('#saveQuestionBtn').prop('disabled', true).text('Kaydediliyor...');

                
                $.ajax({
                    url: '/Teacher/AddQuestion',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        examId: examId,
                        questionText: questionText,
                        points: points
                    }),
                    success: function (res) {
                        if (!res.status) {
                            showAlert('Soru eklenemedi: ' + res.message, 'danger');
                            $btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i>Soruyu Kaydet');
                            return;
                        }

                        var newQuestionId = res.data;

                
                        var promises = options.map(function (opt) {
                            return $.ajax({
                                url: '/Teacher/AddOption',
                                type: 'POST',
                                contentType: 'application/json',
                                data: JSON.stringify({
                                    examQuestionId: newQuestionId,
                                    optionText: opt.text,
                                    isCorrect: opt.isCorrect
                                })
                            });
                        });

                        $.when.apply($, promises).then(function () {
                            showAlert('Soru eklendi!', 'success');
                          
                            $('#QuestionText').val('');
                            $('#Points').val(10);
                            $('#optionsList').empty();
                            optionCount = 0;
                            addOptionRow('', false);
                            addOptionRow('', false);
                            addOptionRow('', false);
                            addOptionRow('', false);
                            $('input[name="correctOption"]').first().prop('checked', true);
                            loadExistingQuestions(); 
                            $btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i>Soruyu Kaydet');
                        }, function () {
                            showAlert('Şıklar eklenirken hata oluştu.', 'danger');
                            $btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i>Soruyu Kaydet');
                        });
                    },
                    error: function (xhr) {
                        showAlert('Hata: ' + (xhr.responseJSON?.message || 'Soru eklenemedi'), 'danger');
                        $btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i>Soruyu Kaydet');
                    }
                });
            });


                $(document).on('click', '.btn-delete-question', function () {
                    var id = $(this).data('id');

                    Swal.fire({
                        title: 'Emin misiniz?',
                        text: "Bu soruyu silmek istediğinize emin misiniz? Bu işlem geri alınamaz!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#dc3545', 
                        cancelButtonColor: '#6c757d', 
                        confirmButtonText: '<i class="fas fa-trash me-1"></i> Evet, Sil!',
                        cancelButtonText: 'İptal'
                    }).then((result) => {
                        if (result.isConfirmed) {

                            $.ajax({
                                url: `/Teacher/DeleteQuestion/${id}`,
                                type: 'DELETE',
                                success: function (res) {
                                    showAlert(res.message || 'Soru silindi.', res.status ? 'success' : 'danger');
                                    if (res.status) loadExistingQuestions();
                                },
                                error: function (xhr) {
                                    showAlert('Hata: ' + (xhr.responseJSON?.message || 'Silinemedi'), 'danger');
                                }
                            });
                        }
                    });
                });


            $(document).on('click', '.btn-edit-question', function () {
                var id = $(this).data('id');
                var text = $(this).data('text');
                var points = $(this).data('points');
                $('#editQuestionId').val(id);
                $('#editQuestionText').val(text);
                $('#editPoints').val(points);
                $('#editQuestionModal').modal('show');
            });


            $('#btnUpdateQuestion').click(function () {
                var id = parseInt($('#editQuestionId').val());
                var text = $('#editQuestionText').val().trim();
                var points = parseInt($('#editPoints').val());

           
                if (!text) { showAlert('Soru metni boş olamaz.', 'warning'); return; }

         
                if (points < 1) { showAlert('Puan en az 1 olmalıdır.', 'warning'); return; }


                $.ajax({
                    url: '/Teacher/UpdateQuestion',
                    type: 'PUT',
                    contentType: 'application/json',
                    data: JSON.stringify({ Id: id, QuestionText: text, Points: points }),
                    success: function (res) {
                        if (res.status) {
                            $('#editQuestionModal').modal('hide');
                            showAlert('Soru güncellendi.', 'success');
                            loadExistingQuestions();
                        } else {
                            showAlert('Güncelleme başarısız: ' + res.message, 'danger');
                        }
                    },
                    error: function (xhr) {
                        showAlert('Hata: ' + (xhr.responseJSON?.message || 'Güncellenemedi'), 'danger');
                    }
                });
            });
        });
    </script>
}