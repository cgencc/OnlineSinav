@model object
@{
    ViewData["Title"] = "Sınav Geçmişim";
    var results = Model as IEnumerable<dynamic>;
}

<h2 class="mb-4"><i class="fas fa-history me-2"></i>Sınav Geçmişim</h2>
@if (results == null || !results.Any())
{
    <div class="alert alert-info">Henüz katıldığınız bir sınav bulunmuyor.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr><th>Sınav</th><th>Puan</th><th>Tarih</th></tr>
        </thead>
        <tbody>
            @foreach (var item in results)
            {
                <tr>
                    <td>@item.ExamTitle</td>
                    <td>@item.Score</td>
                    <td>@item.Date</td>
                </tr>
            }
        </tbody>
    </table>
}