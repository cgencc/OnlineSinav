@model List<OnlineSinav.MVC.Models.DTOs.ExamListDto>
@{
    ViewData["Title"] = "Mevcut Sinavlar";
}

<h2 class="mb-4 fw-bold"><i class="fas fa-pencil-alt me-2 text-primary"></i>Mevcut Sinavlar</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info border-0 shadow-sm">
        <i class="fas fa-info-circle me-2"></i>Simdilik aktif bir sinav bulunmuyor.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var exam in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@exam.Title</h5>
                        <div class="text-muted small mb-3">
                            <i class="fas fa-clock me-1"></i>@exam.DurationInMinutes dakika
                            &nbsp;|&nbsp;
                            <i class="fas fa-question-circle me-1"></i>@exam.QuestionCount soru
                        </div>
                        @if (exam.StartDate.HasValue || exam.EndDate.HasValue)
                        {
                            <div class="alert alert-warning py-2 px-3 small mb-3">
                                @if (exam.StartDate.HasValue)
                                {
                                    <div><i class="fas fa-calendar-check me-1"></i>Baslangic: @exam.StartDate.Value.ToString("dd.MM.yyyy HH:mm")</div>
                                }
                                @if (exam.EndDate.HasValue)
                                {
                                    <div><i class="fas fa-calendar-times me-1"></i>Bitis: @exam.EndDate.Value.ToString("dd.MM.yyyy HH:mm")</div>
                                }
                            </div>
                        }
                        <div class="mt-auto">
                            <a href="/Student/TakeExam/@exam.Id" class="btn btn-primary w-100 rounded-pill">
                                <i class="fas fa-play me-2"></i>Sinava Gir
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
