@model List<OnlineSinav.MVC.Models.DTOs.ExamListDto>
@{
    ViewData["Title"] = "Sınavlarım";
}

<h2 class="mb-4">Aktif Sınavlar</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Henüz aktif sınav bulunmamaktadır.</div>
}
else
{
    <div class="row">
        @foreach (var exam in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@exam.Title</h5>
                        <p class="card-text">
                            <small class="text-muted">
                                Süre: @exam.DurationInMinutes dk | Soru: @exam.QuestionCount
                            </small>
                        </p>
                        <p class="card-text"><small class="text-muted">Oluşturulma: @exam.CreatedDate.ToString("dd.MM.yyyy")</small></p>
                        <a href="/Student/TakeExam/@exam.Id" class="btn btn-primary">Sınava Gir</a>
                    </div>
                </div>
            </div>
        }
    </div>
}